{
  "name": "datavia",
  "productName": "Datavia",
  "version": "2.5.1",
  "description": "Datavia — Navicat 风格的数据库管理工具，内置 AI 助手与生产库危险 SQL 二次确认 (MySQL / MariaDB / PostgreSQL / SQLite / SQL Server / ClickHouse / OceanBase)",
  "main": "src/main/main.js",
  "author": "Datavia",
  "license": "MIT",
  "packageManager": "npm@9.6.5",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "selftest": "electron . --selftest",
    "verify": "npm run selftest && npm run smoke",
    "integration": "node scripts/integration-db.js",
    "demo": "electron . --demo",
    "icon": "node scripts/gen-icon.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps || echo skip-native-rebuild"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@clickhouse/client": "^1.20.0",
    "better-sqlite3": "^12.2.0",
    "codemirror": "^5.65.16",
    "egoroof-blowfish": "^4.0.2",
    "exceljs": "^4.4.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "sax": "^1.6.0",
    "sql-formatter": "^15.8.1",
    "sql.js": "^1.13.0",
    "ssh2": "^1.17.0"
  },
  "build": {
    "appId": "com.datavia.app",
    "productName": "Datavia",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sql.js/dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Datavia"
    }
  }
}
