{
  "name": "dbconnect",
  "productName": "DBConnect",
  "version": "2.1.2",
  "description": "Navicat 风格的数据库连接管理工具 (MySQL / PostgreSQL / SQLite / SQL Server)",
  "main": "src/main/main.js",
  "author": "dbconnect",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "selftest": "electron . --selftest",
    "demo": "electron . --demo",
    "icon": "node scripts/gen-icon.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps || echo skip-native-rebuild"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@clickhouse/client": "^1.20.0",
    "better-sqlite3": "^12.2.0",
    "codemirror": "^5.65.16",
    "exceljs": "^4.4.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "sql-formatter": "^15.8.1",
    "sql.js": "^1.13.0",
    "ssh2": "^1.17.0"
  },
  "build": {
    "appId": "com.dbconnect.app",
    "productName": "DBConnect",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sql.js/dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DBConnect"
    }
  }
}
